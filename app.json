{
  "expo": {
    "name": "RepGather",
    "slug": "repgather",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "repgather",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pushuppro",
      "infoPlist": {
        "NSHealthShareUsageDescription": "RepGather reads your step count from Apple Health to automatically track progress in your walking challenges.",
        "NSHealthUpdateUsageDescription": "RepGather writes your workout progress back to Apple Health to keep your health data in sync."
      }
    },
    "android": {
      "package": "com.pushuppro",
      "adaptiveIcon": {
        "backgroundColor": "#0D1117",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "RepGather reads your step count from Apple Health to automatically track progress in your walking challenges.",
          "healthUpdatePermission": "RepGather writes your workout progress back to Apple Health to keep your health data in sync."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
